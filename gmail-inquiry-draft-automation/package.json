{
  "name": "gmail-inquiry-draft-automation",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "vite build && cp appsscript.json dist/appsscript.json",
    "watch": "tsc --watch",
    "push": "pnpm build && clasp push -u ${CLASP_USER:?CLASP_USER is not set}",
    "deploy": "clasp deploy -u ${CLASP_USER:?CLASP_USER is not set}",
    "open": "clasp open-script -u ${CLASP_USER:?CLASP_USER is not set}",
    "sync-props": "infisical run -- node scripts/sync-script-properties.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint src",
    "format": "biome format --write src",
    "check": "biome check --write src",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/google-apps-script": "catalog:",
    "@google/clasp": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
