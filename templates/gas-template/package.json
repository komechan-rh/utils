{
  "name": "gas-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc && cp appsscript.json dist/appsscript.json",
    "watch": "tsc --watch",
    "push": "pnpm build && clasp push",
    "deploy": "clasp deploy",
    "open": "clasp open-script",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint src",
    "format": "biome format --write src",
    "check": "biome check --write src",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/google-apps-script": "^1.0.7",
    "clasp": "^1.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
